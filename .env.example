# Copy this file to `.env` and fill in your real keys.
# The .env file is git-ignored so your keys never end up on GitHub.

# Google Gemini — used for embeddings (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Groq — used for generating answers (get one at https://console.groq.com/keys)
GROQ_API_KEY=

# Qdrant Cloud — vector database (create a free cluster at https://cloud.qdrant.io)
QDRANT_URL=
QDRANT_API_KEY=

# Where the Streamlit UI finds the backend (leave as-is for local development)
BACKEND_URL=http://localhost:8000

# Portkey LLM gateway — optional; adds latency/cost dashboards, caching,
# and fallbacks (get one at https://portkey.ai). Leave blank to call Groq
# directly.
PORTKEY_API_KEY=
PORTKEY_PROVIDER_SLUG=

# Logfire (optional) — pipeline tracing dashboard (get one at https://logfire.pydantic.dev)
# Leave blank: tracing becomes a no-op, nothing is sent anywhere.
LOGFIRE_TOKEN=
